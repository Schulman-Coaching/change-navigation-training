---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

const allWorkshops = await getCollection('workshops');

// Sort by start date
const sorted = allWorkshops.sort((a, b) => {
  const da = new Date(a.data.startDate).getTime();
  const db = new Date(b.data.startDate).getTime();
  return da - db;
});

const juneWorkshops = sorted.filter((w) => w.data.cohort === 'June 2026');
const julyWorkshops = sorted.filter((w) => w.data.cohort === 'July 2026');

const levelLabels: Record<string, string> = {
  'beginner': 'Beginner',
  'intermediate': 'Intermediate',
  'all-levels': 'All Levels',
};

const categoryLabels: Record<string, string> = {
  'ai-literacy': 'AI Literacy',
  'change-navigation': 'Change Navigation',
  'practical-tools': 'Practical Tools',
  'career': 'Career',
  'education': 'Education',
};
---

<BaseLayout
  title="Upcoming Classes & Workshops — Change Navigation Training"
  description="View our upcoming workshops for June and July 2026. AI literacy, change navigation, career development, and more. Designed for Orthodox Jewish women."
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Upcoming Classes</h1>
        <p>Summer 2026. Four workshops in June. Four in July. Every session designed for women who want to move forward with clarity.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="schedule-note">
          <p>All workshops are live, online, and designed for Orthodox Jewish women. Scheduling respects Shabbat and Yom Tov. No sessions on Friday evening or Saturday.</p>
        </div>

        <!-- June 2026 -->
        <h2 class="month-heading">June 2026</h2>
        <div class="workshop-grid">
          {juneWorkshops.map((w) => {
            const { data } = w;
            const startDate = new Date(data.startDate);
            const startStr = startDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
            return (
              <div class="workshop-card">
                <div class="card-header">
                  <span class="level-badge level--{data.level}">{levelLabels[data.level]}</span>
                  <span class="category-badge">{categoryLabels[data.category]}</span>
                </div>
                <h3><a href={`/workshops/${data.slug}/`}>{data.title}</a></h3>
                <p class="excerpt">{data.excerpt}</p>
                <div class="card-details">
                  <div class="detail">
                    <span class="detail-label">Starts</span>
                    <span class="detail-value">{startStr}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">When</span>
                    <span class="detail-value">{data.dayOfWeek}, {data.time} {data.timezone}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">Format</span>
                    <span class="detail-value">{data.sessions} sessions &middot; {data.duration}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">Price</span>
                    <span class="detail-value detail-price">{data.price}</span>
                  </div>
                </div>
                <div class="card-actions">
                  <a href={`/workshops/${data.slug}/`} class="btn btn-sm">View Details</a>
                  <a href="/contact/" class="btn btn-outline btn-sm">Register</a>
                </div>
              </div>
            );
          })}
        </div>

        <!-- July 2026 -->
        <h2 class="month-heading">July 2026</h2>
        <div class="workshop-grid">
          {julyWorkshops.map((w) => {
            const { data } = w;
            const startDate = new Date(data.startDate);
            const startStr = startDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
            return (
              <div class="workshop-card">
                <div class="card-header">
                  <span class="level-badge level--{data.level}">{levelLabels[data.level]}</span>
                  <span class="category-badge">{categoryLabels[data.category]}</span>
                </div>
                <h3><a href={`/workshops/${data.slug}/`}>{data.title}</a></h3>
                <p class="excerpt">{data.excerpt}</p>
                <div class="card-details">
                  <div class="detail">
                    <span class="detail-label">Starts</span>
                    <span class="detail-value">{startStr}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">When</span>
                    <span class="detail-value">{data.dayOfWeek}, {data.time} {data.timezone}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">Format</span>
                    <span class="detail-value">{data.sessions} sessions &middot; {data.duration}</span>
                  </div>
                  <div class="detail">
                    <span class="detail-label">Price</span>
                    <span class="detail-value detail-price">{data.price}</span>
                  </div>
                </div>
                <div class="card-actions">
                  <a href={`/workshops/${data.slug}/`} class="btn btn-sm">View Details</a>
                  <a href="/contact/" class="btn btn-outline btn-sm">Register</a>
                </div>
              </div>
            );
          })}
        </div>

        <div class="schedule-footer text-center">
          <h2>Can't Find What You Need?</h2>
          <p style="color: var(--color-gray-light); margin: 1rem 0 1.5rem;">
            New workshops are added monthly. Private coaching and organizational training are also available.
          </p>
          <div class="footer-actions">
            <a href="/private-coaching/" class="btn btn-outline">Private Coaching</a>
            <a href="/organizational-training/" class="btn btn-outline">Organizational Training</a>
            <a href="/contact/" class="btn">Contact Us</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <CTABanner />
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-black), #1a1410);
    padding: 5rem 1.5rem 3rem;
    text-align: center;
    border-bottom: 3px solid var(--color-gold);
  }
  .page-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 0.5rem; }
  .page-hero p { color: var(--color-gray-light); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

  .schedule-note {
    background: var(--color-dark);
    border-left: 3px solid var(--color-gold);
    padding: 1rem 1.5rem;
    margin-bottom: 3rem;
  }
  .schedule-note p { font-size: 0.85rem; color: var(--color-gray-light); font-style: italic; }

  .month-heading {
    font-size: 2rem;
    color: var(--color-gold);
    margin: 3rem 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-gray);
  }
  .month-heading:first-of-type { margin-top: 0; }

  .workshop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .workshop-card {
    background: var(--color-dark);
    border: 1px solid var(--color-gray);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }
  .workshop-card:hover { border-color: var(--color-gold); }

  .card-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .level-badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.6rem;
    font-weight: 600;
  }
  .level--beginner { background: #1a3a2a; color: #4ade80; }
  .level--intermediate { background: #1a2a3a; color: #60a5fa; }
  .level--all-levels { background: #2a1a3a; color: #c084fc; }

  .category-badge {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    background: var(--color-gray);
    color: var(--color-gray-light);
  }

  .workshop-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .workshop-card h3 a { color: var(--color-white); }
  .workshop-card h3 a:hover { color: var(--color-gold); }

  .excerpt {
    font-size: 0.85rem;
    color: var(--color-gray-light);
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
  }

  .card-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    padding: 0.75rem;
    background: var(--color-black);
  }

  .detail { display: flex; flex-direction: column; gap: 0.15rem; }
  .detail-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-gray); }
  .detail-value { font-size: 0.8rem; color: var(--color-white); }
  .detail-price { color: var(--color-gold); font-family: var(--font-display); font-size: 0.9rem; }

  .card-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-sm {
    font-size: 0.75rem;
    padding: 0.5rem 1rem;
    flex: 1;
  }

  .schedule-footer {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-gray);
  }
  .footer-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .workshop-grid {
      grid-template-columns: 1fr;
    }
    .card-details {
      grid-template-columns: 1fr;
    }
  }
</style>
