---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout
  title="Private Coaching — Change Navigation Training"
  description="One-on-one change navigation coaching for Orthodox Jewish women. Personalized AI literacy, career transition, and change-readiness guidance. Sessions available individually or in packages."
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Private Coaching</h1>
        <p>Personalized guidance for your change journey</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="intro">
          <h2>Work One-on-One</h2>
          <p>Private coaching provides focused, personalized guidance for your specific goals. Whether you are navigating a career transition, building confidence with AI tools, or simply want a structured space to think through what comes next, private sessions adapt to your context and pace.</p>
          <p>Coaching is not teaching. It is guided exploration. You bring the questions. We bring frameworks, tools, and honest reflection.</p>
        </div>
      </div>
    </section>

    <section class="pricing-section section">
      <div class="container">
        <h2 class="text-center">Pricing</h2>
        <div class="pricing-grid">
          <div class="price-card">
            <h3>Single Session — 60min</h3>
            <p class="amount">$125<span>/session</span></p>
            <h4>Multi-Session Savings</h4>
            <p>4 Sessions: $450</p>
            <p>8 Sessions: $840</p>
            <p>12 Sessions: $1,200</p>
          </div>

          <div class="price-card price-card--featured">
            <span class="badge">Most Popular</span>
            <h3>Change Navigation Intensive</h3>
            <p class="amount">$840</p>
            <p>8 sessions over 8 weeks. Includes a personal change map, AI literacy assessment, and a concrete 90-day action plan.</p>
          </div>

          <div class="price-card">
            <h3>AI Onboarding Package</h3>
            <p class="amount">$350</p>
            <p>3 focused sessions to get you comfortable with AI tools for your specific context — work, business, or personal use. Hands-on, practical, zero jargon.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section text-center">
      <div class="container">
        <h2>Ready to Begin?</h2>
        <p style="color: var(--color-gray-light); margin: 1rem 0 1.5rem;">Schedule a free 20-minute call to discuss what you need and how coaching can help.</p>
        <a href="/contact/" class="btn">Book a Consultation</a>
      </div>
    </section>
  </main>

  <CTABanner />
  <Footer />
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-black), #1a1410);
    padding: 5rem 1.5rem 3rem;
    text-align: center;
    border-bottom: 3px solid var(--color-gold);
  }
  .page-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 0.5rem; }
  .page-hero p { color: var(--color-gray-light); font-size: 1.1rem; }

  .intro { max-width: 700px; margin: 0 auto; text-align: center; }
  .intro h2 { margin-bottom: 1rem; }
  .intro p { color: var(--color-gray-light); margin-bottom: 1rem; font-size: 1.05rem; }

  .pricing-section { background: var(--color-dark); }

  .pricing-grid {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .price-card {
    background: var(--color-black);
    border: 1px solid var(--color-gray);
    padding: 2rem;
    min-width: 260px;
    max-width: 320px;
    flex: 1;
    text-align: center;
    position: relative;
  }

  .price-card--featured { border-color: var(--color-gold); }

  .badge {
    position: absolute; top: 0; left: 50%; transform: translate(-50%, -50%);
    background: var(--color-gold); color: var(--color-black); padding: 0.3rem 1rem;
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
  }

  .amount {
    font-family: var(--font-display);
    font-size: 2.5rem;
    margin: 0.5rem 0 1rem;
    color: var(--color-gold);
  }

  .amount span { font-size: 0.8rem; color: var(--color-gray-light); font-family: var(--font-body); }

  .price-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .price-card h4 { font-size: 0.85rem; color: var(--color-gold); margin: 1.5rem 0 0.5rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .price-card p { font-size: 0.85rem; color: var(--color-gray-light); margin-bottom: 0.25rem; }
</style>
