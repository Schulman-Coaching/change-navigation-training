---
import { NAV_ITEMS, SITE } from '../config';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label={`${SITE.name} Home`}>
      <span class="logo-text">CHANGE NAVIGATION <span class="text-gold">TRAINING</span></span>
      <span class="logo-tagline">{SITE.tagline}</span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {NAV_ITEMS.map(item => (
          <li class="nav-item">
            <a
              href={item.href}
              class={`nav-link ${isActive(item.href) ? 'active' : ''}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/schedule/" class="btn nav-cta">View Schedule</a>

    <button class="mobile-toggle" aria-label="Toggle menu" id="mobile-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const nav = document.querySelector('.nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('nav--open');
    toggle.classList.toggle('open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-gray);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
  }

  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.05em;
  }

  .logo-tagline {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gray-light);
    margin-top: 2px;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 0;
  }

  .nav-link {
    display: block;
    padding: 0.4rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-light);
    transition: color 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-gold);
  }

  .nav-cta {
    font-size: 0.8rem;
    padding: 0.5rem 1.25rem;
    flex-shrink: 0;
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-white);
    transition: all 0.3s;
  }

  @media (max-width: 1100px) {
    .nav {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-black);
      padding: 2rem 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s;
      overflow-y: auto;
    }

    .nav--open { transform: translateX(0); }

    .nav-list {
      flex-direction: column;
      gap: 0.5rem;
    }

    .nav-link {
      font-size: 1.1rem;
      padding: 0.75rem 0;
    }

    .mobile-toggle { display: flex; }
    .nav-cta { display: none; }
  }
</style>
