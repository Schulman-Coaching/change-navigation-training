---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout
  title="Change Navigation Training — Navigate AI Change With Confidence"
  description="Change Navigation Training helps Orthodox Jewish women build the skills, confidence, and clarity to navigate change — personal, professional, and technological. Workshops, coaching, and community for thriving in the AI era."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-content container">
        <h1 class="hero-title">
          Navigate Change<br/>
          <span class="text-gold">With Confidence</span>
        </h1>
        <p class="hero-subtitle">
          AI isn't the disruption. Your response to it is. Practical skills for Orthodox Jewish women
          who want to move forward with clarity, not fear.
        </p>
        <div class="hero-actions">
          <a href="/group-workshops/" class="btn">View Workshops</a>
          <a href="/memberships/" class="btn btn-outline">See Memberships</a>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="mission section">
      <div class="container">
        <div class="mission-grid">
          <div class="mission-text">
            <h2>Our Mission</h2>
            <p class="mission-lead">
              We help Orthodox Jewish women build the skills to navigate change — personal,
              professional, and technological — with confidence and clarity.
            </p>
            <p>
              Change is not a disruption to manage. It is a skill to develop. Our training goes
              beyond learning AI tools. It is about cultivating the mindset to see change clearly,
              respond thoughtfully, and move forward with agency.
            </p>
            <div class="mission-stats">
              <div class="stat">
                <span class="stat-number">12+</span>
                <span class="stat-label">Workshop Modules</span>
              </div>
              <div class="stat">
                <span class="stat-number">6</span>
                <span class="stat-label">Peer Circles</span>
              </div>
              <div class="stat">
                <span class="stat-number">200+</span>
                <span class="stat-label">Women Trained</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Training Philosophy -->
    <section class="philosophy section">
      <div class="container text-center">
        <h2>Our Approach</h2>
        <p class="philosophy-lead">
          Change is uncomfortable. That is not a problem to solve. It is the signal that growth is happening.
        </p>
        <div class="philosophy-grid">
          <div class="philosophy-item">
            <h3>Clarity</h3>
            <p>Learn to assess what is changing and what it means — for your work, your family, and yourself.</p>
            <div class="bar"><span class="bar-fill" style="--w:90%"></span></div>
            <span class="bar-label">90%</span>
          </div>
          <div class="philosophy-item">
            <h3>Confidence</h3>
            <p>Build the unshakeable belief that you can handle what comes next — with AI or without it.</p>
            <div class="bar"><span class="bar-fill" style="--w:95%"></span></div>
            <span class="bar-label">95%</span>
          </div>
          <div class="philosophy-item">
            <h3>Adaptability</h3>
            <p>Develop the skill of learning itself. The ability to face new tools, new roles, and new realities without freezing.</p>
            <div class="bar"><span class="bar-fill" style="--w:88%"></span></div>
            <span class="bar-label">88%</span>
          </div>
          <div class="philosophy-item">
            <h3>Agency</h3>
            <p>Move from feeling like change is happening to you — to knowing you have a say in where you are going.</p>
            <div class="bar"><span class="bar-fill" style="--w:85%"></span></div>
            <span class="bar-label">85%</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Programs -->
    <section class="programs section">
      <div class="container">
        <h2 class="text-center">Our Programs</h2>
        <p class="programs-subtitle text-center">A path for every woman</p>
        <div class="programs-grid">
          <a href="/group-workshops/" class="program-card">
            <h3 class="font-display">Group Workshops</h3>
            <p>Hands-on sessions. AI tools, change frameworks, and practical skills in a supportive group setting.</p>
          </a>
          <a href="/womens-ai-confidence/" class="program-card">
            <h3 class="font-display">Women's AI Confidence</h3>
            <p>Our flagship program. Build AI literacy and change-navigation skills over 8 weeks.</p>
          </a>
          <a href="/community/" class="program-card">
            <h3 class="font-display">Peer Learning Circles</h3>
            <p>Small groups of women learning together. Monthly topics, shared accountability, real support.</p>
          </a>
          <a href="/organizational-training/" class="program-card">
            <h3 class="font-display">Organizational Training</h3>
            <p>For schools, nonprofits, and businesses. Help your team or community navigate AI change together.</p>
          </a>
          <a href="/private-coaching/" class="program-card">
            <h3 class="font-display">Private Coaching</h3>
            <p>One-on-one sessions. Personalized guidance for your specific change journey.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials section">
      <div class="container">
        <h2 class="text-center">What Women Say</h2>
        <div class="testimonials-grid">
          <blockquote class="testimonial-card">
            <p>"I came in afraid of AI. I left knowing I could use it to my advantage. More importantly, I stopped feeling like change was something that happened to me."</p>
            <cite>&mdash; Chana R.</cite>
          </blockquote>
          <blockquote class="testimonial-card">
            <p>"The workshops gave me language for what I was feeling. And practical tools for what to do about it. I use what I learned every week."</p>
            <cite>&mdash; Miriam S., Workshop Graduate</cite>
          </blockquote>
          <blockquote class="testimonial-card">
            <p>"I didn't just learn about AI. I learned about myself. About how I respond to change. That was the real gift."</p>
            <cite>&mdash; Devorah K.</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Blog Preview -->
    <section class="blog-preview section">
      <div class="container">
        <div class="blog-preview-header">
          <h2>Navigate Change With Confidence</h2>
          <p class="blog-preview-subtitle">Latest from our blog</p>
        </div>
        <div class="blog-preview-grid">
          <div class="blog-preview-card">
            <h3>AI Is Not the Disruption. Your Response to It Is.</h3>
            <p>Why the most important skill in the age of AI is not technical — it is the ability to face change without freezing.</p>
            <a href="/blog/ai-is-not-the-disruption/" class="btn">Read More</a>
          </div>
          <div class="blog-preview-card">
            <h3>What Learning to Use AI Actually Teaches You</h3>
            <p>The tool matters less than what the learning process reveals about your own adaptability.</p>
            <a href="/blog/what-learning-ai-teaches-you/" class="btn">Read More</a>
          </div>
        </div>
        <div class="text-center">
          <a href="/blog/" class="btn btn-outline">Read the Blog</a>
        </div>
      </div>
    </section>

    <!-- Membership Preview -->
    <section class="section" style="background: var(--color-dark);">
      <div class="container text-center">
        <h2>Our Memberships</h2>
        <p class="programs-subtitle">Flexible options for every journey</p>
        <div class="pricing-row">
          <div class="pricing-card">
            <h3>Monthly Explorer</h3>
            <p class="pricing-amount">$89<span>/mo</span></p>
            <p class="pricing-note">All workshops. Peer circle access. Resource library.</p>
          </div>
          <div class="pricing-card pricing-card--featured">
            <h3>Annual Navigator</h3>
            <p class="pricing-amount">$69<span>/mo</span></p>
            <p class="pricing-note">Best value. Paid once annually. Priority coaching access.</p>
          </div>
          <div class="pricing-card">
            <h3>6-Month Journey</h3>
            <p class="pricing-amount">$79<span>/mo</span></p>
            <p class="pricing-note">All workshops. All peer circles. Resource library.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <CTABanner />
  <Footer />
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1410 50%, #0d0a05 100%);
    padding: 6rem 1.5rem 5rem;
    text-align: center;
    border-bottom: 3px solid var(--color-gold);
  }

  .hero-content { max-width: 800px; }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--color-gray-light);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .mission { text-align: center; }
  .mission-grid { max-width: 700px; margin: 0 auto; }

  .mission-lead {
    font-size: 1.2rem;
    color: var(--color-white);
    margin: 1rem 0;
  }

  .mission p {
    color: var(--color-gray-light);
    font-size: 1.05rem;
  }

  .mission-stats {
    display: flex;
    gap: 2rem;
    justify-content: center;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .stat { text-align: center; }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-gold);
    line-height: 1;
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray-light);
    margin-top: 0.25rem;
  }

  .philosophy { background: var(--color-dark); }

  .philosophy-lead {
    font-size: 1.2rem;
    color: var(--color-gray-light);
    max-width: 600px;
    margin: 0 auto 3rem;
    font-style: italic;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .philosophy-item {
    background: var(--color-black);
    border: 1px solid var(--color-gray);
    padding: 2rem;
    text-align: left;
  }

  .philosophy-item h3 { font-size: 1.3rem; margin-bottom: 0.75rem; }
  .philosophy-item p { font-size: 0.85rem; color: var(--color-gray-light); margin-bottom: 1rem; }

  .bar {
    height: 4px;
    background: var(--color-gray-dark);
    margin-bottom: 0.5rem;
  }

  .bar-fill {
    display: block;
    height: 100%;
    background: var(--color-gold);
    width: var(--w);
  }

  .bar-label {
    font-size: 0.75rem;
    color: var(--color-gold);
    font-weight: 600;
  }

  .programs { text-align: center; }
  .programs-subtitle { color: var(--color-gray-light); margin-bottom: 2.5rem; }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .program-card {
    background: var(--color-dark);
    border: 1px solid var(--color-gray);
    padding: 2rem;
    text-align: left;
    transition: border-color 0.2s;
  }

  .program-card:hover { border-color: var(--color-gold); }
  .program-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--color-gold); }
  .program-card p { font-size: 0.85rem; color: var(--color-gray-light); line-height: 1.5; }

  .testimonials { background: var(--color-dark); }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .testimonial-card {
    background: var(--color-black);
    border-left: 3px solid var(--color-gold);
    padding: 1.5rem 2rem;
    margin: 0;
  }

  .testimonial-card p {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-off-white);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .testimonial-card cite {
    font-size: 0.85rem;
    color: var(--color-gray-light);
    font-style: normal;
  }

  .blog-preview { text-align: center; }
  .blog-preview-header { margin-bottom: 2rem; }
  .blog-preview-subtitle { color: var(--color-gray-light); margin-top: 0.5rem; }

  .blog-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .blog-preview-card {
    background: var(--color-dark);
    border: 1px solid var(--color-gray);
    padding: 2rem;
    text-align: left;
  }

  .blog-preview-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    color: var(--color-gold);
  }

  .blog-preview-card p {
    font-size: 0.9rem;
    color: var(--color-gray-light);
    margin-bottom: 1.5rem;
  }

  .pricing-row {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .pricing-card {
    background: var(--color-black);
    border: 1px solid var(--color-gray);
    padding: 2rem;
    min-width: 240px;
    max-width: 300px;
    text-align: center;
  }

  .pricing-card--featured { border-color: var(--color-gold); }

  .pricing-card h3 { font-size: 1.2rem; margin-bottom: 0.75rem; }

  .pricing-amount {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }

  .pricing-amount span {
    font-size: 1rem;
    color: var(--color-gray-light);
    font-family: var(--font-body);
  }

  .pricing-note {
    font-size: 0.85rem;
    color: var(--color-gray-light);
  }

  @media (max-width: 768px) {
    .hero { padding: 4rem 1.5rem 3rem; }
    .blog-preview-grid { grid-template-columns: 1fr; }
  }
</style>
