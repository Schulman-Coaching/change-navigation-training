---
export interface Props {
  title: string;
  slug: string;
  date: string;
  excerpt?: string;
  categories?: string[];
}

const { title, slug, date, excerpt, categories } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card">
  <div class="blog-card-body">
    {categories && categories.length > 0 && (
      <div class="blog-card-categories">
        {categories.slice(0, 3).map(cat => (
          <span class="blog-card-category">{cat}</span>
        ))}
      </div>
    )}
    <h3 class="blog-card-title">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    {excerpt && <p class="blog-card-excerpt">{excerpt}</p>}
    <time class="blog-card-date" datetime={date}>{formattedDate}</time>
  </div>
</article>

<style>
  .blog-card {
    background: var(--color-dark);
    border: 1px solid var(--color-gray);
    padding: 1.75rem;
    transition: border-color 0.2s;
  }

  .blog-card:hover {
    border-color: var(--color-gold);
  }

  .blog-card-categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .blog-card-category {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    background: rgba(200, 150, 62, 0.1);
    padding: 0.2rem 0.6rem;
  }

  .blog-card-title {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .blog-card-title a {
    color: var(--color-white);
    transition: color 0.2s;
  }

  .blog-card-title a:hover {
    color: var(--color-gold);
  }

  .blog-card-excerpt {
    font-size: 0.85rem;
    color: var(--color-gray-light);
    margin-bottom: 1rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-date {
    font-size: 0.75rem;
    color: var(--color-gray-light);
  }
</style>
